{
  "id": "agent-passport",
  "name": "Agent Passport",
  "description": "Scanner-first trust layer for poisoned skills, plugins, drift review, runtime policy checks, and audit logging in OpenClaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["audit", "warn", "enforce"],
        "default": "warn"
      },
      "pathModes": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "message_sending": { "type": "string", "enum": ["audit", "warn", "enforce"] },
          "message.send": { "type": "string", "enum": ["audit", "warn", "enforce"] },
          "sessions_send": { "type": "string", "enum": ["audit", "warn", "enforce"] }
        },
        "default": {}
      },
      "defaultPolicy": {
        "type": "string",
        "enum": ["allow", "deny", "require-consent"],
        "default": "require-consent"
      },
      "trustedTargets": {
        "type": "array",
        "items": { "type": "string" },
        "default": []
      },
      "trustedTargetRules": {
        "type": "array",
        "default": [],
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "target": { "type": "string" },
            "paths": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["all", "message_sending", "message.send", "sessions_send"]
              },
              "default": ["all"]
            },
            "note": { "type": "string" }
          },
          "required": ["target"]
        }
      },
      "consentTtlMinutes": {
        "type": "integer",
        "minimum": 1,
        "default": 60
      },
      "categories": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "exec": { "type": "string", "enum": ["allow", "deny", "require-consent"] },
          "externalMessaging": { "type": "string", "enum": ["allow", "deny", "require-consent"] },
          "privateNetworkAccess": { "type": "string", "enum": ["allow", "deny", "require-consent"] },
          "fileDelete": { "type": "string", "enum": ["allow", "deny", "require-consent"] },
          "configMutation": { "type": "string", "enum": ["allow", "deny", "require-consent"] },
          "pluginInstall": { "type": "string", "enum": ["allow", "deny", "require-consent"] }
        }
      },
      "audit": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "store": { "type": "string", "enum": ["local-jsonl"], "default": "local-jsonl" },
          "path": { "type": "string", "default": ".openclaw/agent-passport/audit.jsonl" }
        }
      }
    }
  }
}
